{
  "name": "chess-wasm",
  "version": "1.0.0",
  "scripts": {
    "test": "node tests",
    "asbuild:debug": "asc assembly/index.ts --target debug --exportRuntime --outFile build/debug.wasm",
    "asbuild:release": "asc assembly/index.ts --target release --exportRuntime --outFile build/release.wasm",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "start": "npx serve ."
  },
  "devDependencies": {
    "assemblyscript": "^0.27.37"
  }
}
